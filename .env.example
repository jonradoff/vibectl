# VibeCtl Environment Configuration
# Copy this file to .env and fill in values for local development.
# For production, set these as environment variables in whatever way your
# host supports (.env file, system env, Docker --env-file, Fly.io secrets, etc.)

# ─── Required ────────────────────────────────────────────────────────────────

# MongoDB connection string
# Local:      mongodb://localhost:27017
# Atlas/prod: mongodb+srv://user:pass@cluster.mongodb.net/
MONGODB_URI=mongodb://localhost:27017

# MongoDB database name — use different names to keep dev and prod data isolated
DATABASE_NAME=vibectl

# ─── Networking ──────────────────────────────────────────────────────────────

# HTTP port (default: 4380)
PORT=4380

# Base URL for this server — used for OAuth callback redirects
# Local: http://localhost:4380
# Prod:  https://your-vibectl-domain.example.com
BASE_URL=http://localhost:4380

# CORS origins for the frontend (comma-separated)
# Local: http://localhost:4370
# Prod:  https://your-vibectl-domain.example.com
ALLOWED_ORIGINS=http://localhost:4370

# ─── AI ──────────────────────────────────────────────────────────────────────

# Anthropic API key — enables AI triage, issue summaries, PM review, and auto-regen.
# Get one at: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ─── GitHub — OAuth login ─────────────────────────────────────────────────────
#
# Enables "Continue with GitHub" on the login screen. When users log in via
# GitHub, their OAuth token is automatically stored and used for clone/pull/push.
#
# Setup:
#   1. Go to github.com/settings/developers → OAuth Apps → New OAuth App
#   2. Set Authorization callback URL to: {BASE_URL}/api/v1/auth/github/callback
#   3. Copy the Client ID and generate a Client Secret
#   4. Fill in the values below and restart VibeCtl
#
# The Setup Guide in Settings → GitHub also has step-by-step instructions.

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── GitHub — API token (CI status) ──────────────────────────────────────────
#
# A server-level read token used to fetch commit history and CI check run status
# in the CI tab. This is separate from per-user OAuth tokens used for git ops.
#
# Setup:
#   1. Go to github.com/settings/tokens → Tokens (classic) → Generate new token
#   2. Select repo scope (or public_repo if all repos are public)
#   3. Copy the token and fill in the value below
#
# Without this, the GitHub API rate limit is 60 req/hour for the whole server.
# With it you get 5 000/hour. The CI tab will show an error until this is set.

GITHUB_TOKEN=

# ─── Security ────────────────────────────────────────────────────────────────

# AES-256-GCM key for encrypting stored per-user API keys and GitHub tokens.
# Generate with:  openssl rand -hex 16
# Must be exactly 32 hex characters. Keep this consistent across restarts —
# changing it will make all stored encrypted values unreadable.
API_KEY_ENCRYPTION_KEY=

# ─── Repos directory ─────────────────────────────────────────────────────────

# Where cloned repos are stored on the server (default: /data/repos)
# REPOS_DIR=/data/repos
